{
  "name": "lorekeeper",
  "version": "1.0.0",
  "description": "Lorekeeping application for worldbuilding",
  "scripts": {
    "build": "npm run build:api && webpack --mode production && npm run package",
    "build:api": "webpack --config webpack.api.config.js",
    "package": "node scripts/package.js",
    "dev": "webpack --mode development --watch",
    "link-sdk": "npm link @applicator/sdk"
  },
  "dependencies": {
    "@applicator/sdk": "file:../system/sdk",
    "next": "^16.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "archiver": "^5.3.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.4.4",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  }
}
